<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net">
  <diagram name="AutoDeploy-Pipeline">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="827" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="2" value="AutoDeploy — CI/CD Pipeline Architecture" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="250" y="30" width="600" height="40" as="geometry"/>
        </mxCell>

        <!-- GitHub Push -->
        <mxCell id="gh" value="👩‍💻 Developer&#xa;git push origin main" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="460" y="100" width="200" height="65" as="geometry"/>
        </mxCell>

        <!-- Arrow -->
        <mxCell id="a1" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#555;strokeWidth=2;" edge="1" source="gh" target="gha" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a1l" value="Triggers" style="edgeLabel;html=1;fontSize=11;" vertex="1" connectable="0" parent="a1">
          <mxGeometry relative="0.5" as="geometry"/>
