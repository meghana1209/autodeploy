        <mxCell id="a3pl" value="✅ PASS" style="edgeLabel;html=1;fontSize=11;fontColor=#007700;fontStyle=1;" vertex="1" connectable="0" parent="a3p">
          <mxGeometry relative="0.5" as="geometry"/>
        </mxCell>

        <!-- FAIL branch -->
        <mxCell id="a3f" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#CC0000;strokeWidth=2;exitX=1;exitY=0.5;entryX=0.5;entryY=0;" edge="1" source="test" target="fail" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a3fl" value="❌ FAIL" style="edgeLabel;html=1;fontSize=11;fontColor=#CC0000;fontStyle=1;" vertex="1" connectable="0" parent="a3f">
          <mxGeometry relative="0.5" as="geometry"/>
        </mxCell>

        <!-- Fail box -->
        <mxCell id="fail" value="🚫 Deploy Blocked&#xa;Notify developer&#xa;No code reaches prod" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffcccc;strokeColor=#CC0000;fontSize=11;" vertex="1" parent="1">
