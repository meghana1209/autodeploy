        <!-- GitHub Actions -->
        <mxCell id="gha" value="⚙️ GitHub Actions&#xa;CI Runner (ubuntu-latest)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="420" y="240" width="280" height="65" as="geometry"/>
        </mxCell>

        <!-- Arrow to test -->
        <mxCell id="a2" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#555;strokeWidth=2;" edge="1" source="gha" target="test" parent="1">
